{
    "git": {
        "commitMessage": "chore: release v${version}",
        "tagName": "v${version}",
        "requireCleanWorkingDir": false,
        "add": [
            "package.json",
            "armoris-x402-agent-pay/armoris-x402-agent-pay.php",
            "armoris-x402-agent-pay/readme.txt",
            "armoris-x402-agent-pay/CHANGELOG.md",
            "armoris-x402-agent-pay/languages/armoris-x402-agent-pay.pot"
        ]
    },
    "github": {
        "release": true,
        "assets": [
            "armoris-x402-agent-pay.zip"
        ]
    },
    "npm": {
        "publish": false
    },
    "hooks": {
        "after:bump": "node scripts/bump-version.js ${version} && ./scripts/pack-plugin.sh"
    },
    "plugins": {}
}